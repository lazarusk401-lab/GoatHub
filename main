-- Import necessary libraries
local game = game
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Create a toggle for speed
local SpeedToggle = Instance.new("BoolValue")
SpeedToggle.Name = "EnableSpeed"
SpeedToggle.Value = true

-- Create a slider for speed amount
local SpeedSlider = Instance.new("Slider")
SpeedSlider.Name = "SpeedAmount"
SpeedSlider.MaxDecimalPlaces = 2
SpeedSlider.MinValue = 0
SpeedSlider.MaxValue = 100
SpeedSlider.Parent = game.Workspace
SpeedSlider.Parent = ReplicatedStorage

-- Set up the slider's onchanged event
SpeedSlider.OnChanged:Connect(function(value)
    print("New speed value:", value)
end)

-- Create a toggle for flying
local FlyToggle = Instance.new("BoolValue")
FlyToggle.Name = "EnableFly"
FlyToggle.Value = false

-- Create a variable to store the fly speed
local FlySpeed = 100

-- Set up the main menu function
local function MainMenu()
    -- TO DO: implement main menu logic here
end

-- Set up the commands function
local function Commands()
    -- TO DO: implement command logic here
end

-- Function to handle speed toggle change
local function OnSpeedToggleChanged(oldValue, newValue)
    if newValue then
        game.Workspace:WaitForChild("SpeedSlider").Enabled = true
        game.Workspace:WaitForChild("FlyToggle").Enabled = true
    else
        game.Workspace:WaitForChild("SpeedSlider").Enabled = false
        game.Workspace:WaitForChild("FlyToggle").Enabled = false
    end
end

-- Connect to the speed toggle changed event
SpeedToggle.OnChanged:Connect(OnSpeedToggleChanged)

-- Set up the main menu tab's onactivated event
local function OnMainMenuActivated()
    MainMenu()
end

-- Connect to the main menu tab's onactivated event
TabControl:FindFirstChild("Main Menu"):OnActivated:Connect(OnMainMenuActivated)

-- Function to handle fly toggle change
local function OnFlyToggleChanged(oldValue, newValue)
    if newValue then
        FlySpeed = tonumber(game.Workspace:WaitForChild("SpeedSlider").Value)
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(game.Workspace.CurrentFrame.X, 1.5, game.Workspace.CurrentFrame.Z) -- Fly to the top of the screen

        -- Set up smooth animation for flying
        local flyAnim = Instance.new("BehaviorTreeService")
        flyAnim.Name = "FlyAnim"
        flyAnim.Parent = game

        -- Create a new behavior tree root task
        local flyTask = Instance.new("BehaviorTreeTask")
        flyTask.Name = "FlyToTarget"

        -- Set up the fly to target task
        local function FlyToTarget(parent)
            while true do
                parent.CFrame = CFrame.new(game.Workspace.CurrentFrame.X, game.Workspace.CurrentFrame.Y + math.sin(Time.time * 10) * FlySpeed / 100, game.Workspace.CurrentFrame.Z)
                wait(0.01)
            end
        end

        -- Connect to the fly task's onexecute event
        flyTask.OnExecute:Connect(FlyToTarget)

        -- Start the behavior tree
        flyAnim:start(flyTask)
    else
        -- Stop the smooth animation
        game:FindFirstChild("FlyAnim"):Destroy()
    end
end

-- Connect to the fly toggle changed event
FlyToggle.OnChanged:Connect(OnFlyToggleChanged)

-- Set up the main menu tab's onactivated event
TabControl:FindFirstChild("Commands"):OnActivated:Connect(function()
    Commands()
end)
