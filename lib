-- Import necessary libraries
local Gui = game:GetService("GuiService")
local RunService = game:GetService("RunService")

-- Create the main frame
local Frame = Instance.new("Frame")
Frame.Name = "GoathubGUI"
Frame.Parent = Gui

-- Set frame properties
Frame.Size = UDim2.new(0, 300, 0, 200)
Frame.BackgroundTransparency = 1
Frame.BackgroundColor3 = Color3.new(1, 1, 1)

-- Create a tab control
local TabControl = Instance.new("TabLayout")
TabControl.Name = "GoathubTabControl"
TabControl.Parent = Frame

-- Create tabs
local Tab1 = Instance.new("Tab")
Tab1.Name = "MainMenu"
Tab1.Text = "Main Menu"

local Tab2 = Instance.new("Tab")
Tab2.Name = "Commands"
Tab2.Text = "Commands"

-- Add tabs to the tab control
Table.insert(TabControl.Tabs, Tab1)
Table.insert(TabControl.Tabs, Tab2)

-- Function to switch between tabs
local function SwitchTabs(tabName)
    for i, v in pairs(TabControl.Tabs) do
        if v.Name == tabName then
            TabControl:SelectTab(i)
            return
        end
    end
end

-- Set up main menu tab
local function SetupMainMenu()
    local Button = Instance.new("Button")
    Button.Name = "Go"
    Button.Text = "GO"
    Button.Parent = Tab1

    -- Connect button click event
    Button.OnActivated:Connect(function()
        -- TO DO: implement main menu logic here
    end)
end

-- Set up commands tab
local function SetupCommandsTab()
    local Text = Instance.new("TextLabel")
    Text.Name = "Welcome"
    Text.Text = "Goathub Commands"
    Text.Parent = Tab2

    -- TO DO: implement command logic here
end

-- Initialize the UI
SetupMainMenu()
SetupCommandsTab()

-- Function to switch between tabs on key press
RunService.RenderStepped:Connect(function(dt)
    if game:GetService("UserInputService"):GetFocusedTextBox() then
        local input = game:GetService("UserInputService"):GetFocusedTextBox().Text
        if input == "main" then
            SwitchTabs("Main Menu")
        elseif input == "commands" then
            SwitchTabs("Commands")
        end
    end
end)
